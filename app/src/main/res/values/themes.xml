<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AIFraudGuard" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Accent and helper colors -->
        <item name="colorAccent">@color/primary</item>
        <item name="android:statusBarColor">@color/purple_700</item>
        
        <!-- Input field aesthetics -->
        <item name="editTextColor">@color/black</item>
    </style>

    <style name="Theme.AIFraudGuard.NoActionBar" parent="Theme.AIFraudGuard">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="CircleImageView" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>