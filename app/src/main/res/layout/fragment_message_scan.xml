<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MessageScanFragment">

    <!-- Header -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_background"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="30dp"
            android:paddingBottom="24dp"
            android:gravity="center_vertical"
            android:elevation="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_message"
                android:contentDescription="Message Scanner"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message Scanner"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Detect SMS &amp; Email fraud"
                    android:textSize="14sp"
                    android:textColor="#E8F5E8" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Message type toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_floating_nav"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/toggleSms"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="📱 SMS"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@android:color/white"
                            android:background="@drawable/bg_top_header"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/toggleEmail"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="✉️ Email"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#94A3B8"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Text input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilMessageInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:hintEnabled="false"
                        app:startIconDrawable="@drawable/ic_message"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMessageInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Paste SMS or Email text here…"
                            android:textColor="#333333"
                            android:textColorHint="#888888"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="4"
                            android:maxLines="10"
                            android:gravity="top"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Analyze button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAnalyze"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:text="🔍  Analyze Message"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        app:cornerRadius="12dp"
                        android:backgroundTint="@color/primary" />

                    <!-- Loading spinner -->
                    <ProgressBar
                        android:id="@+id/progressBarScan"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:visibility="gone" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Result Card (initially hidden) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultCardScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="32dp"
                app:cardElevation="16dp"
                app:strokeWidth="0dp"
                android:visibility="gone"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="28dp"
                    android:paddingBottom="28dp">

                    <!-- Score ring -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="140dp">

                        <com.google.android.material.progressindicator.CircularProgressIndicator
                            android:id="@+id/fraudScoreRing"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:indicatorSize="140dp"
                            app:trackThickness="12dp"
                            app:trackColor="#EEEEEE"
                            app:indicatorColor="#10B981"
                            android:max="100"
                            android:progress="0" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvFraudScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="score"
                                android:textSize="11sp"
                                android:textColor="#757575" />
                        </LinearLayout>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Fraud Score"
                        android:textSize="12sp"
                        android:textColor="#757575" />

                    <!-- Label badge -->
                    <TextView
                        android:id="@+id/tvFraudLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingHorizontal="28dp"
                        android:paddingVertical="8dp"
                        android:text="SAFE"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#10B981"
                        android:background="@drawable/bg_floating_nav" />

                    <!-- Reason text -->
                    <TextView
                        android:id="@+id/tvFraudReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="24dp"
                        android:layout_marginTop="16dp"
                        android:text=""
                        android:textAlignment="center"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:textColor="#444444" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginVertical="20dp"
                        android:layout_marginHorizontal="32dp" />

                    <!-- Matched signals header -->
                    <TextView
                        android:id="@+id/tvSignalsHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="20dp"
                        android:text="Detected Signals"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#555555"
                        android:visibility="gone" />

                    <!-- Matched signals list -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSignals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="16dp"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false" />

                    <!-- Scan Another -->
                    <TextView
                        android:id="@+id/btnScanAnother"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:padding="8dp"
                        android:text="SCAN ANOTHER MESSAGE"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
